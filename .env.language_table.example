# Copy to .env.language_table and edit as needed.

LAMER_DIR=/gpfs/home/memmelma/projects/LaMer
LANGTABLE_DIR=/gpfs/home/memmelma/projects/language-table
LANGTABLE_CONDA_ENV=langtable
LAMER_CONDA_ENV=lamer
CONDA_CACHE_DIR=/gpfs/scrubbed/memmelma/.cache/conda-cache
PIP_CACHE_DIR=/gpfs/scrubbed/memmelma/.cache/pip
TMPDIR=/gpfs/scrubbed/memmelma/.cache/tmp

SLURM_LOG_DIR=/gpfs/scrubbed/memmelma/.cache/slurm_logs

CHECKPOINT_ROOT=/gpfs/scrubbed/memmelma/.cache/checkpoints/lamer
RUN_NAME=language_table_lamer_qwen3_4b

REWARD_TYPE=block2block # block2block, point2block

TRAIN_NUM_ENVS=8
VAL_NUM_ENVS=4
GROUP_SIZE=8
MAX_INNER_STEPS=20 # 100
NUM_ATTEMPTS=3
MAX_TURNS=3

# --- Training hyperparameters ---
LEARNING_RATE=1e-6
BATCH_SIZE=64          # ppo_mini_batch_size
MICRO_BATCH_SIZE=16    # ppo_micro_batch_size_per_gpu

# --- KL divergence (GRPO / GiGPO) ---
USE_KL_LOSS=False              # True to enable KL loss term in the actor loss
KL_LOSS_COEF=0.001             # weight of the KL loss term
KL_LOSS_TYPE=low_var_kl        # low_var_kl | kl
USE_KL_IN_REWARD=False         # True to add KL penalty to the reward
KL_REWARD_COEF=0.001           # weight of the KL reward penalty

VLA_CHECKPOINT_DIR=/gpfs/scrubbed/memmelma/.cache/checkpoints/language_table
VLA_CHECKPOINT=${VLA_CHECKPOINT_DIR}/bc_resnet_sim_checkpoint_955000

HF_HOME=/gpfs/scrubbed/memmelma/.cache/huggingface
WANDB_DATA_DIR=/gpfs/scrubbed/memmelma/.cache/wandb-data
XDG_CACHE_HOME=/gpfs/projects/weirdlab/memmelma/.cache
