# Copy to .env.language_table and edit as needed.

LAMER_DIR=/gpfs/projects/stf/sidhraja/projects/LaMer
LANGTABLE_DIR=/gpfs/projects/stf/sidhraja/projects/language-table
LANGTABLE_CONDA_ENV=ltvenv
LAMER_CONDA_ENV=lamer
CONDA_CACHE_DIR=/gpfs/scrubbed/sidhraja/.cache/conda-cache
PIP_CACHE_DIR=/gpfs/scrubbed/sidhraja/.cache/pip
TMPDIR=/gpfs/scrubbed/sidhraja/.cache/tmp

SLURM_LOG_DIR=/gpfs/scrubbed/sidhraja/.cache/slurm_logs

CHECKPOINT_ROOT=/gpfs/scrubbed/sidhraja/.cache/checkpoints/lamer
RUN_NAME=langtable_multistep_group_size_16_kl_reward_001

REWARD_TYPE=multistep
# JSON kwargs forwarded to the env server's reward factory per split.
# Schema:
#   multistep: {"locations":[...],"shapes":[...],"colors":[...],"n_steps":N}
#   custom:    {} (placeholder; wire real kwargs once API hook is implemented)
#   block2block / point2block / etc.: {}
# TRAIN_REWARD_KWARGS='{"locations":["top_left","top_right","bottom_left","bottom_right"],"shapes":["moon","cube","star","pentagon"],"n_steps":2}'
# VAL_REWARD_KWARGS='{"locations":["top","bottom","center_left","center_right"],"colors":["red","blue","green","yellow"],"n_steps":2}'
REWARD_KWARGS='["T"]'

# Number of blocks per split (BLOCK_1 | BLOCK_4 | BLOCK_8). Independent per split.
TRAIN_BLOCK_MODE=BLOCK_4
VAL_BLOCK_MODE=BLOCK_4

# --- Env debugging ---
# TRAIN_NUM_ENVS=4
# VAL_NUM_ENVS=4
# GROUP_SIZE=4
# MAX_INNER_STEPS=4
# NUM_ATTEMPTS=2
# MAX_TURNS=2

# --- Env parameters
TRAIN_NUM_ENVS=8
VAL_NUM_ENVS=8
GROUP_SIZE=16
MAX_INNER_STEPS=96
NUM_ATTEMPTS=3
MAX_TURNS=4

# --- Training hyperparameters ---
NUM_TRAIN_GPUS=4
LEARNING_RATE=1e-6
BATCH_SIZE=$((TRAIN_NUM_ENVS * GROUP_SIZE))  # ppo_mini_batch_size
MINI_BATCH_PER_GPU=$((BATCH_SIZE / NUM_TRAIN_GPUS))
MICRO_BATCH_SIZE=8 #$((MINI_BATCH_PER_GPU < 32 ? MINI_BATCH_PER_GPU : 32))  # ppo_micro_batch_size_per_gpu

# --- KL divergence (GRPO / GiGPO) ---
USE_KL_LOSS=False              # True to enable KL loss term in the actor loss
KL_LOSS_COEF=0.01 # 0.001       # weight of the KL loss term
KL_LOSS_TYPE=low_var_kl        # low_var_kl | kl
USE_KL_IN_REWARD=True         # True to add KL penalty to the reward
KL_REWARD_COEF=0.01 # 0.001           # weight of the KL reward penalty

# --- OPRO baseline (scripts/submit_baseline_opro.sh / baseline_opro.slurm) ---
# Rollout VLM and meta-LLM for scripts/run_baseline_opro.py (make_vlm_client).
# Values: stub | gemini. For gemini set GOOGLE_API_KEY in .env.language_table.secrets.
export VLM_PROVIDER=stub
export META_LLM_PROVIDER=stub
# export VLM_PROVIDER=gemini
# export META_LLM_PROVIDER=gemini

VLA_CHECKPOINT_DIR=/gpfs/scrubbed/sidhraja/.cache/checkpoints/language_table
VLA_CHECKPOINT=${VLA_CHECKPOINT_DIR}/bc_resnet_sim_checkpoint_955000

HF_HOME=/gpfs/scrubbed/sidhraja/.cache/huggingface
WANDB_DATA_DIR=/gpfs/scrubbed/sidhraja/.cache/wandb-data
XDG_CACHE_HOME=/gpfs/projects/stf/sidhraja/.cache
