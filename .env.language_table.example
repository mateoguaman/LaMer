# Copy to .env.language_table and edit as needed.

LAMER_DIR=/gpfs/home/memmelma/projects/LaMer
LANGTABLE_DIR=/gpfs/home/memmelma/projects/language-table
LANGTABLE_CONDA_ENV=langtable
LAMER_CONDA_ENV=lamer
CONDA_CACHE_DIR=/gpfs/scrubbed/memmelma/.cache/conda-cache
PIP_CACHE_DIR=/gpfs/scrubbed/memmelma/.cache/pip
TMPDIR=/gpfs/scrubbed/memmelma/.cache/tmp

SLURM_LOG_DIR=/gpfs/scrubbed/memmelma/.cache/slurm_logs

CHECKPOINT_ROOT=/gpfs/scrubbed/memmelma/.cache/checkpoints/lamer
RUN_NAME=langtable_multistep_group_size_16_kl_reward_001

REWARD_TYPE=multistep
# --- Multistep task configuration (reward_type=multistep) ---
# Train: push N blocks (described by shape) to corner locations
TRAIN_TASK_LOCATIONS=top_left,top_right,bottom_left,bottom_right
TRAIN_TASK_SHAPES=moon,cube,star,pentagon
TRAIN_TASK_COLORS=
TRAIN_TASK_N_STEPS=2
# Val: push N blocks (described by color) to edge locations
VAL_TASK_LOCATIONS=top,bottom,center_left,center_right
VAL_TASK_SHAPES=
VAL_TASK_COLORS=red,blue,green,yellow
VAL_TASK_N_STEPS=3

# --- Env debugging ---
# TRAIN_NUM_ENVS=4
# VAL_NUM_ENVS=4
# GROUP_SIZE=4
# MAX_INNER_STEPS=4
# NUM_ATTEMPTS=2
# MAX_TURNS=2

# --- Env parameters
TRAIN_NUM_ENVS=8
VAL_NUM_ENVS=8
GROUP_SIZE=16
MAX_INNER_STEPS=128
NUM_ATTEMPTS=3
MAX_TURNS=4

# --- Training hyperparameters ---
NUM_TRAIN_GPUS=4
LEARNING_RATE=1e-6
BATCH_SIZE=$((TRAIN_NUM_ENVS * GROUP_SIZE))  # ppo_mini_batch_size
MINI_BATCH_PER_GPU=$((BATCH_SIZE / NUM_TRAIN_GPUS))
MICRO_BATCH_SIZE=$((MINI_BATCH_PER_GPU < 32 ? MINI_BATCH_PER_GPU : 32))  # ppo_micro_batch_size_per_gpu

# --- KL divergence (GRPO / GiGPO) ---
USE_KL_LOSS=False              # True to enable KL loss term in the actor loss
KL_LOSS_COEF=0.01 # 0.001       # weight of the KL loss term
KL_LOSS_TYPE=low_var_kl        # low_var_kl | kl
USE_KL_IN_REWARD=True         # True to add KL penalty to the reward
KL_REWARD_COEF=0.01 # 0.001           # weight of the KL reward penalty

VLA_CHECKPOINT_DIR=/gpfs/scrubbed/memmelma/.cache/checkpoints/language_table
VLA_CHECKPOINT=${VLA_CHECKPOINT_DIR}/bc_resnet_sim_checkpoint_955000

HF_HOME=/gpfs/scrubbed/memmelma/.cache/huggingface
WANDB_DATA_DIR=/gpfs/scrubbed/memmelma/.cache/wandb-data
XDG_CACHE_HOME=/gpfs/projects/weirdlab/memmelma/.cache
