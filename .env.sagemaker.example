# Copy to .env.sagemaker and edit as needed.
# SageMaker configuration for LaMer + language-table training.

# --- AWS Configuration ---
AWS_REGION=us-west-2
ECR_REPO_NAME=lamer-langtable
IMAGE_TAG=latest

# --- SageMaker ---
# Full ECR image URI (set after running build_and_push.sh)
SAGEMAKER_IMAGE_URI=
# IAM role ARN with SageMaker execution permissions
SAGEMAKER_ROLE=
SAGEMAKER_INSTANCE_TYPE=ml.p4d.24xlarge
SAGEMAKER_VOLUME_SIZE=200
SAGEMAKER_MAX_RUN=86400

# Spot instances (set to true to use spot with automatic checkpoint resume)
SAGEMAKER_USE_SPOT=false

# --- S3 Paths ---
# VLA checkpoint directory in S3 (must contain bc_resnet_sim_checkpoint_955000)
VLA_S3_URI=
# S3 path for checkpoint sync (enables spot resume)
CHECKPOINT_S3_URI=

# --- Training ---
RUN_NAME=language_table_lamer_qwen3_4b
ADV_ESTIMATOR=gigpo

# --- Secrets ---
# WandB API key for logging
WANDB_API_KEY=
# HuggingFace token for model downloads
HF_TOKEN=

# --- language-table repo path (for build_and_push.sh) ---
# LANGTABLE_DIR=/path/to/language-table
