# Copy to .env.azure and edit as needed.
# Azure-specific configuration for LaMer multi-node training.

# --- Azure Resource Configuration ---
AZURE_RESOURCE_GROUP=myresourcegroup
AZURE_LOCATION=westus2
AZURE_SSH_KEY=~/.ssh/azure_key
AZURE_ADMIN_USER=azureuser

# VM names
AZURE_VM_TRAIN_0=vm-train-0
AZURE_VM_TRAIN_1=vm-train-1
AZURE_VM_ENV=vm-env

# VM sizes
AZURE_TRAIN_VM_SIZE=Standard_NC80adis_H100_v5
AZURE_ENV_VM_SIZE=Standard_NC24ads_A100_v4

# --- Repo Paths (on the VMs) ---
LAMER_DIR=/home/${AZURE_ADMIN_USER}/LaMer
LANGTABLE_DIR=/home/${AZURE_ADMIN_USER}/language-table

# --- Git Repos (for cloning onto VMs) ---
LAMER_GIT_REPO=
LANGTABLE_GIT_REPO=

# --- Conda Environments ---
LAMER_CONDA_ENV=lamer
LANGTABLE_CONDA_ENV=ltvenv

# --- Training Configuration ---
CHECKPOINT_ROOT=/home/${AZURE_ADMIN_USER}/checkpoints/lamer
RUN_NAME=language_table_lamer_qwen3_4b
VLA_CHECKPOINT_DIR=/home/${AZURE_ADMIN_USER}/checkpoints/language_table

# --- Env Server Ports ---
TRAIN_PORT=50051
VAL_PORT=50052

# --- HuggingFace ---
HF_HOME=/home/${AZURE_ADMIN_USER}/.cache/huggingface
